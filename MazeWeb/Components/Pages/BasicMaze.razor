@page "/BasicMaze"
@using Microsoft.Extensions.WebEncoders.Testing
@using Microsoft.VisualBasic
@using labyrinth
@using MermaidJS.Blazor

<PageTitle>Basic Maze Visualizer</PageTitle>

<h1>Enter your name</h1>
<input @bind="userName" />
<button @onclick="generateMaze">Generate Basic Maze</button>

<MermaidDiagram Definition=@mazeBody />

@code
{
    string userName;
    string mazeBody;
    private void generateMaze()
    {
        (var links, mazeBody, var startingLocation) = MazeGenerator.GenerateMaze(userName, isTwisty: false);
    }
}
